# =============================================================================
# Tradewind — LOCAL DEVELOPMENT
# =============================================================================
# Copy to .env.local and fill in real values. Never commit .env.local.
# All VITE_* values are PUBLIC (shipped to the browser). Anything secret
# must live in Supabase Function Secrets, never here.
# =============================================================================

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=YOUR_LOCAL_OR_DEV_SUPABASE_ANON_KEY

# Stripe mode — keep "test" locally. "live" enables real charges.
VITE_STRIPE_MODE=test
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe TEST-mode price IDs (created in Stripe Dashboard → Test Mode)
VITE_STRIPE_PRICE_FEATURED_LISTING=price_test_xxx
VITE_STRIPE_PRICE_BOOST_LISTING=price_test_xxx
VITE_STRIPE_PRICE_DEALER_STARTER=price_test_xxx
VITE_STRIPE_PRICE_DEALER_PRO=price_test_xxx
VITE_STRIPE_PRICE_DEALER_PREMIER=price_test_xxx
VITE_STRIPE_PRICE_SERVICE_PROVIDER=price_test_xxx
VITE_STRIPE_PRICE_CONCIERGE=price_test_xxx

# Optional public APIs
VITE_GOOGLE_MAPS_API_KEY=

# Optional — Sentry DSN (leave blank to disable client error reporting)
VITE_SENTRY_DSN=

# Optional — surfaces env name in UI ("local" | "staging" | "production")
VITE_ENV_NAME=local

# Optional — Cal.com/Calendly URL for the "Book 10-Minute Feedback Call"
# CTA. If unset, the button routes to /feedback (no dead links).
# See go-to-market/CALENDAR_LINK_SETUP.md for setup instructions.
VITE_FEEDBACK_CALL_URL=

# Business identity (public) — override src/lib/brand.ts per environment.
VITE_BUSINESS_NAME=Tradewind
# Leave support email unset locally to use the brand.ts fallback.
# VITE_BUSINESS_SUPPORT_EMAIL=

# CAN-SPAM postal address. Leave UNSET locally to keep email outreach scaling
# blocked (the server gate is what actually matters). Production value:
# 790 E Broward Blvd, Fort Lauderdale, FL 33301
VITE_BUSINESS_MAILING_ADDRESS=
