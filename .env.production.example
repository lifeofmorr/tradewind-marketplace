# =============================================================================
# Tradewind — PRODUCTION (Vercel main + Supabase qwaotydaazymgnvnfuuj)
# =============================================================================
# Set in Vercel → Settings → Environment Variables → Production scope, and
# Supabase Function Secrets via `supabase secrets set --project-ref qwaotydaazymgnvnfuuj`.
#
# HARD RULES:
# 1. Never write production secrets to disk on a developer laptop.
# 2. Stripe LIVE keys only after dry-run on staging (see PAYMENT_PRODUCTION_READINESS.md).
# 3. Service-role key never leaves Supabase Function Secrets.
# 4. Rotate any key that appears in a screenshot, log, or shared message.
# =============================================================================

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://qwaotydaazymgnvnfuuj.supabase.co
VITE_SUPABASE_ANON_KEY=PROD_SUPABASE_ANON_KEY

# Stripe mode gate — "live" enables real charges. Checkout fails closed unless
# the publishable key is pk_live_… AND all 7 live price IDs below are set. Keep
# this "test" until /admin/payments/live-readiness shows all-green.
VITE_STRIPE_MODE=live
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Stripe LIVE price IDs (recreate the 7 SKUs in Live mode)
VITE_STRIPE_PRICE_FEATURED_LISTING=price_live_xxx
VITE_STRIPE_PRICE_BOOST_LISTING=price_live_xxx
VITE_STRIPE_PRICE_DEALER_STARTER=price_live_xxx
VITE_STRIPE_PRICE_DEALER_PRO=price_live_xxx
VITE_STRIPE_PRICE_DEALER_PREMIER=price_live_xxx
VITE_STRIPE_PRICE_SERVICE_PROVIDER=price_live_xxx
VITE_STRIPE_PRICE_CONCIERGE=price_live_xxx

VITE_GOOGLE_MAPS_API_KEY=

# Sentry — production DSN (separate project from staging)
VITE_SENTRY_DSN=

VITE_ENV_NAME=production

# Business identity (public). Name + support email feed src/lib/brand.ts.
VITE_BUSINESS_NAME=Tradewind
# Support inbox. PENDING: Don is creating a dedicated Gmail. Until that inbox is
# live, LEAVE THIS UNSET so brand.ts falls back to the current monitored address
# (don@lifeofmorr.com). Target placeholder once active: tradewindsupport@gmail.com
# VITE_BUSINESS_SUPPORT_EMAIL=tradewindsupport@gmail.com   # PENDING CONFIRMATION

# CAN-SPAM — physical postal address shown in email footers + cold outreach.
# Required before outreach can scale (build-daily-queue refuses to run without
# the server-side BUSINESS_MAILING_ADDRESS). Real address or CMRA/PO box.
# CONFIRMED 2026-06-03.
VITE_BUSINESS_MAILING_ADDRESS=790 E Broward Blvd, Fort Lauderdale, FL 33301

# =============================================================================
# Supabase Function Secrets (production)
# =============================================================================
# STRIPE_MODE=live                            # MUST match VITE_STRIPE_MODE ("test" default)
# BUSINESS_MAILING_ADDRESS=790 E Broward Blvd, Fort Lauderdale, FL 33301   # CONFIRMED 2026-06-03; must match VITE_BUSINESS_MAILING_ADDRESS
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_live_xxx        # from Stripe Live mode webhook
# STRIPE_PRICE_FEATURED_LISTING=price_live_xxx
# STRIPE_PRICE_BOOST_LISTING=price_live_xxx
# STRIPE_PRICE_DEALER_STARTER=price_live_xxx
# STRIPE_PRICE_DEALER_PRO=price_live_xxx
# STRIPE_PRICE_DEALER_PREMIER=price_live_xxx
# STRIPE_PRICE_SERVICE_PROVIDER=price_live_xxx
# STRIPE_PRICE_CONCIERGE=price_live_xxx
# SUPABASE_URL=https://qwaotydaazymgnvnfuuj.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...prod...        # NEVER share, NEVER log
# SUPABASE_ANON_KEY=...
# APP_URL=https://gotradewind.com
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=...
# OPENAI_FALLBACK_MODEL=gpt-4o-mini
# RESEND_API_KEY=...                          # verified domain sender
# RESEND_FROM=Tradewind <hello@gotradewind.com>
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=production
# ALLOWED_ORIGINS=https://gotradewind.com,https://www.gotradewind.com
