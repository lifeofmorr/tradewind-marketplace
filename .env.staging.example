# =============================================================================
# Tradewind — STAGING (Vercel Preview)
# =============================================================================
# Set these in Vercel → Settings → Environment Variables → Preview scope.
# Staging always uses Stripe TEST keys, Plaid sandbox, and a SEPARATE Supabase
# project from production. Never reuse production secrets here.
# =============================================================================

# --- Frontend (Vite) — exposed to browser ---
VITE_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_STAGING_SUPABASE_ANON_KEY

# Staging is ALWAYS test mode — never set this to "live" on Preview.
VITE_STRIPE_MODE=test
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe TEST-mode price IDs (mirrors of prod, in Test mode)
VITE_STRIPE_PRICE_FEATURED_LISTING=price_test_xxx
VITE_STRIPE_PRICE_BOOST_LISTING=price_test_xxx
VITE_STRIPE_PRICE_DEALER_STARTER=price_test_xxx
VITE_STRIPE_PRICE_DEALER_PRO=price_test_xxx
VITE_STRIPE_PRICE_DEALER_PREMIER=price_test_xxx
VITE_STRIPE_PRICE_SERVICE_PROVIDER=price_test_xxx
VITE_STRIPE_PRICE_CONCIERGE=price_test_xxx

VITE_GOOGLE_MAPS_API_KEY=

# Sentry — separate project from prod so noise is isolated
VITE_SENTRY_DSN=

VITE_ENV_NAME=staging

# Business identity (public)
VITE_BUSINESS_NAME=Tradewind
# VITE_BUSINESS_SUPPORT_EMAIL=                 # leave unset to use brand.ts fallback
# Staging can carry the real address to exercise the CAN-SPAM footer in previews.
VITE_BUSINESS_MAILING_ADDRESS=790 E Broward Blvd, Fort Lauderdale, FL 33301

# =============================================================================
# Supabase Function Secrets (set via `supabase secrets set --project-ref <staging>`)
# These are SERVER-SIDE only — do not prefix with VITE_, do not commit.
# =============================================================================
# STRIPE_MODE=test                            # staging is always test
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_test_xxx        # SEPARATE secret from prod
# STRIPE_PRICE_FEATURED_LISTING=price_test_xxx
# STRIPE_PRICE_BOOST_LISTING=price_test_xxx
# STRIPE_PRICE_DEALER_STARTER=price_test_xxx
# STRIPE_PRICE_DEALER_PRO=price_test_xxx
# STRIPE_PRICE_DEALER_PREMIER=price_test_xxx
# STRIPE_PRICE_SERVICE_PROVIDER=price_test_xxx
# STRIPE_PRICE_CONCIERGE=price_test_xxx
# SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...staging...     # never share with prod
# SUPABASE_ANON_KEY=...
# APP_URL=https://tradewind-marketplace.vercel.app
# ANTHROPIC_API_KEY=...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=...                          # optional fallback
# OPENAI_FALLBACK_MODEL=gpt-4o-mini
# RESEND_API_KEY=...                          # use sandbox sender
# RESEND_FROM=Tradewind Staging <staging@gotradewind.com>
# PLAID_CLIENT_ID=                            # leave blank for sandbox stub
# PLAID_SECRET=
# PLAID_ENV=sandbox
# ALLOWED_ORIGINS=                            # optional extra origins
# BUSINESS_MAILING_ADDRESS=                   # required to test outreach scaling
